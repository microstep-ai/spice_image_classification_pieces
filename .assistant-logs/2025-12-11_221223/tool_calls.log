{"timestamp": "2025-12-11T22:13:00", "tool": "write", "args": {"files": [{"path": "docs/graphs/ImageClassificationInferencePiece_internal.txt", "content": "@startuml\nskinparam activity {\n  BackgroundColor White\n  BorderColor Black\n  ArrowColor Black\n  FontName Helvetica\n}\n\ntitle ImageClassificationInferencePiece \u2013 internal flow (high level)\n\nstart\n\npartition \"Setup\" {\n  :Receive InputModel(saved_model_path, inference_data_path);\n  :Load Keras model\n  from saved_model_path/best_model.keras;\n  :Read config.json from saved_model_path\n  -> cfg = { image_size, class_mapping, ... };\n  :results = [];\n}\n\npartition \"Per-image loop\" {\n  repeat\n    :Select next img_name from inference_data_path;\n    :Load image with target_size = cfg.image_size;\n    :img_array = img_to_array(image);\n    :batch = expand_dims(img_array, axis=0);\n    :preds = model.predict(batch);\n    :class_id = argmax(preds);\n    :class_name = cfg.class_mapping[str(class_id)];\n    :results.append({\n      image: img_name,\n      class_id: class_id,\n      class: class_name\n    });\n  repeat while (more images?) is (yes)\n}\n\n:Return OutputModel(\n  classification_results = results\n);\n\nstop\n\n@enduml"}]}}
